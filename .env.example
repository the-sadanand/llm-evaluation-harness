# ─────────────────────────────────────────────────────────────
# LLM Evaluation Harness — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Provider selection: use "ollama" for a free local model, or "gemini"/"anthropic" for cloud APIs
LLM_PROVIDER=ollama

# Optional: local Ollama settings
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Optional: your Google API key if you want to use Gemini instead
GOOGLE_API_KEY=

# Optional: your Anthropic API key if you want to use Anthropic instead
ANTHROPIC_API_KEY=

# Optional: Model to evaluate (defaults to a local Ollama model if provider is ollama)
TARGET_MODEL=llama3.2:3b

# Optional: Model used as judge for LLM-as-Judge scoring
JUDGE_MODEL=llama3.2:3b

# Optional: Limit runs to a smaller number of prompts to avoid quota exhaustion
MAX_CALLS=3

# Optional: Gemini retry/backoff settings for rate-limit handling
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=5
