# ─────────────────────────────────────────────────────────────
# LLM Evaluation Harness — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Provider selection: use "gemini" for Google Gemini or "anthropic" for Anthropic
LLM_PROVIDER=gemini

# Required for Gemini: your Google API key (get one at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# Optional: your Anthropic API key if you want to use Anthropic instead
ANTHROPIC_API_KEY=

# Optional: Model to evaluate (defaults to gemini-2.0-flash for Gemini or claude-haiku-4-5-20251001 for Anthropic)
TARGET_MODEL=gemini-2.0-flash

# Optional: Model used as judge for LLM-as-Judge scoring
JUDGE_MODEL=gemini-2.0-flash

# Optional: Limit runs to a smaller number of prompts to avoid quota exhaustion
MAX_CALLS=10

# Optional: Gemini retry/backoff settings for rate-limit handling
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY=5
